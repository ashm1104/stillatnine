# ============================================================
# Still at Nine — Environment Variables
# Copy to .env.local and fill in. Never commit real keys.
# ============================================================

# ---- Site ----
# Canonical production URL (used for OG/Twitter absolute image URLs, etc.)
NEXT_PUBLIC_SITE_URL=https://stillatnine.com

# ---- Supabase (Postgres + Edge Functions) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Full access — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
# From-name "Still at Nine", from-address stories@stillatnine.com
RESEND_FROM_EMAIL=stories@stillatnine.com
# Replies to transactional email reach a human.
RESEND_REPLY_TO=hello@stillatnine.com
# Svix signing secret for the Resend webhook (bounce / complaint / open).
# Resend dashboard -> Webhooks -> your endpoint. Starts with "whsec_".
RESEND_WEBHOOK_SECRET=

# ---- Email management links (no-login signed tokens) ----
# HMAC secret for unsubscribe/manage tokens. Any long random string.
# MUST be identical in Vercel AND in Supabase Edge Function secrets, or the
# story-email unsubscribe links won't verify. Generate: openssl rand -hex 32
UNSUBSCRIBE_TOKEN_SECRET=

# ---- Dodo Payments (Merchant of Record) ----
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
# Checkout link base. Public so the client CTA can build the redirect.
NEXT_PUBLIC_DODO_CHECKOUT_BASE_URL=https://checkout.dodopayments.com/buy
# Geo-detected product IDs (one-time purchase).
NEXT_PUBLIC_DODO_PRODUCT_ID_USD=
NEXT_PUBLIC_DODO_PRODUCT_ID_INR=

# ---- Delivery scheduler (cron-job.org -> Supabase Edge Function) ----
# Shared secret the cron caller must present to trigger a delivery run.
CRON_SECRET=
